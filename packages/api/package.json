{
  "name": "@swush/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/services/index.js",
  "module": "./dist/services/index.js",
  "types": "./dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js",
      "require": "./dist/services/index.js",
      "default": "./dist/services/index.js"
    }
  },
  "files": [
    "dist",
    ".papi/descriptors",
    ".papi/metadata",
    ".papi/polkadot-api.json",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev:tsup": "tsup --watch",
    "dev": "tsx watch src/server.ts",
    "clean": "rimraf dist .papi",
    "lint": "eslint services --ext .ts",
    "test": "jest",
    "papi": "papi",
    "start": "node dist/server.js",
    "dev:server": "tsx watch src/server.ts",
    "postinstall": "papi"
  },
  "dependencies": {
    "@acala-network/chopsticks": "^1.0.1",
    "@acala-network/chopsticks-core": "^1.0.1",
    "@acala-network/chopsticks-testing": "^1.0.1",
    "@acala-network/chopsticks-utils": "^1.0.1",
    "@galacticcouncil/api-augment": "^0.3.0",
    "@galacticcouncil/sdk": "^5.1.0",
    "@galacticcouncil/xcm-cfg": "^6.0.1",
    "@galacticcouncil/xcm-sdk": "^7.0.1",
    "@polkadot-labs/hdkd": "^0.0.10",
    "@polkadot-labs/hdkd-helpers": "^0.0.10",
    "@polkadot/api": "^15.1.1",
    "@polkadot/types": "^15.1.1",
    "@polkadot/types-augment": "^15.2.1",
    "@polkadot/util": "^13.2.3",
    "polkadot-api": "^1.9.4",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "rxjs": "^7.8.1",
    "viem": "^2.22.2",
    "ws": "^8.18.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@polkadot-api/cli": "^0.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/ws": "^8.5.13",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0"
  },
  "pnpm": {
    "overrides": {
      "@polkadot/api": "^15.1.1",
      "@polkadot/types": "^15.1.1",
      "@polkadot/types-augment": "^15.2.1",
      "@polkadot/util": "^13.2.3",
      "@polkadot/util-crypto": "^13.2.3"
    }
  },
  "packageManager": "pnpm@9.13.0+sha512.beb9e2a803db336c10c9af682b58ad7181ca0fbd0d4119f2b33d5f2582e96d6c0d93c85b23869295b765170fbdaa92890c0da6ada457415039769edf3c959efe",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
