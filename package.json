{
  "name": "swush-me",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r --filter @swush/api --filter @swush/web dev",
    "dev:api": "pnpm --filter @swush/api dev",
    "dev:ui": "pnpm --filter @swush/web dev",
    "dev:with-chopsticks": "cd apps/web && pnpm run dev:all",
    "dev:all": "pnpm run dev & pnpm start-chopsticks",
    "demo": "docker compose -f docker-compose.dev.yml up -d && pnpm dev:ui",
    "demo:start": "docker compose -f docker-compose.dev.yml up -d",
    "demo:stop": "docker compose -f docker-compose.dev.yml down",
    "demo:restart": "pnpm demo:stop && pnpm demo",
    "demo:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:restart": "bash packages/deploy/restart-dev.sh",
    "dev:logs": "tail -f dev-output.log",
    "app:restart": "bash packages/deploy/restart.sh",
    "app:logs": "tail -f output.log",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start-chopsticks": "npx @acala-network/chopsticks xcm -p packages/chopsticks/config/polkadot_asset_hub.yml -p packages/chopsticks/config/hydration.yml"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@9.13.0",
  "dependencies": {
    "@acala-network/chopsticks": "^1.0.5",
    "@galacticcouncil/api-augment": "^0.3.1",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-labs/hdkd-helpers": "^0.0.10",
    "@polkadot/api": "~14.0.1",
    "@polkadot/util-crypto": "^13.4.3",
    "@supabase/supabase-js": "^2.49.4",
    "polkadot-api": "^1.13.0",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "overrides": {
      "@polkadot/api": "~14.0.1"
    }
  }
}