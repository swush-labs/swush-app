{
  "name": "swush-me",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @swush/web build",
    "dev": "pnpm --filter @swush/web dev",
    "dev:all": "pnpm dev & pnpm start-chopsticks",
    "clean": "pnpm -r clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start-chopsticks": "npx @acala-network/chopsticks@latest xcm -p packages/chopsticks/config/polkadot_asset_hub.yml -p packages/chopsticks/config/hydration.yml -p packages/chopsticks/config/bifrost.yml -p packages/chopsticks/config/acala.yml -p packages/chopsticks/config/moonbeam.yml",
    "postinstall": ""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@9.13.0",
  "dependencies": {
    "@acala-network/chopsticks": "^1.0.5",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-labs/hdkd-helpers": "^0.0.10",
    "@supabase/supabase-js": "^2.49.4",
    "polkadot-api": "^1.20.0",
    "@polkadot/util-crypto": "^13.4.3",
    "ws": "^8.18.0",
    "@sodazone/ocelloids-client": "^3.0.1"

  },
  "pnpm": {
    "overrides": {
      "@polkadot/api": "~14.0.1"
    }
  }
}