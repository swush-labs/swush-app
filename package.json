{
  "name": "swush-me",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r --filter @swush/api --filter @swush/web dev",
    "dev:api": "pnpm --filter @swush/api dev",
    "dev:ui": "pnpm --filter @swush/web dev",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@9.13.0",
  "dependencies": {
    "@polkadot/util-crypto": "^13.4.3"
  }
}
