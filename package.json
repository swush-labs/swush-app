{
  "name": "swush-me",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@swush/api",
    "dev:ui": "turbo run dev --filter=@swush/web",
    "dev:all": "turbo run dev --parallel --filter=@swush/api --filter=@swush/web",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "postinstall": "papi"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "turbo": "^1.12.2",
    "typescript": "^5.3.3",
    "polkadot-api": "^1.9.4"
  },
  "packageManager": "pnpm@9.13.0",
  "dependencies": {
    "@polkadot/util-crypto": "^13.4.3"
  }
}
