{
  "name": "swush-me",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r --filter @swush/api --filter @swush/web dev",
    "dev:api": "pnpm --filter @swush/api dev",
    "dev:ui": "pnpm --filter @swush/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "papi": "papi"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@9.13.0",
  "dependencies": {
    "@galacticcouncil/api-augment": "^0.3.1",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-labs/hdkd-helpers": "^0.0.10",
    "@polkadot/api": "^15.9.2",
    "@polkadot/util-crypto": "^13.4.3",
    "polkadot-api": "^1.9.4"
  }
}
