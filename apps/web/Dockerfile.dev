FROM node:20-slim

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.13.0 --activate

# Copy workspace files
COPY pnpm-workspace.yaml ./
COPY package.json ./
COPY apps/web/tsconfig.json ./
COPY tsconfig.base.json ./
COPY .papi ./.papi

# Set working directory for web
WORKDIR /app/apps/web

# Copy package files and chopsticks config
COPY apps/web/package.json ./

# Install dependencies
RUN pnpm install

# Default to localhost for development
ENV NEXT_PUBLIC_API_HOST=localhost
ENV NEXT_PUBLIC_USE_LOCAL_ENDPOINTS=true

EXPOSE 3000

# Run both chopsticks and Next.js dev server
CMD ["pnpm", "dev"] 